generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  email    String    @unique
  password String
  name     String
  skills   Skill[]
  projects Project[]
  posts Post[]
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  techStack   String[]
  link        String?
  github      String?
  images      String[]
  createdAt   DateTime @default(now())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  level     Int      @default(0)
  icon      String?
  category  String?
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique 
  content   String   @db.Text
  coverImg  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}
